# Docker Compose maps Postgres to host port 5433 (see docker-compose.yml).
# After migrate deploy: from repo root run `npm run db:seed` (loads departments, skills, demo user).
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/agentos
REDIS_URL=redis://localhost:6379
ANTHROPIC_API_KEY=replace_me
JWT_SECRET=replace_with_a_random_string_at_least_32_chars
PORT=4000
NODE_ENV=development
UPLOAD_DIR=./uploads
FRONTEND_URL=http://localhost:3000

# Optional — Voyage embeddings API uses an API key (from Voyage dashboard), not a project id.
# VOYAGE_API_KEY=

# Optional — override Claude model id
# CLAUDE_MODEL=claude-sonnet-4-5-20250929
