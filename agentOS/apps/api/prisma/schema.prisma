generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("ceo")
  createdAt    DateTime @default(now())
  agents       Agent[]
  tasks        Task[]
}

model Department {
  id              String          @id @default(cuid())
  name            String          @unique
  slug            String          @unique
  description     String
  icon            String
  color           String
  agents          Agent[]
  skillCategory   SkillCategory?
}

model SkillCategory {
  id           String   @id @default(cuid())
  name         String   @unique
  slug         String   @unique
  description  String
  icon         String
  color        String
  sortOrder    Int      @default(0)
  departmentId String?  @unique
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  skills       Skill[]
}

model Skill {
  id             String        @id @default(cuid())
  slug           String        @unique
  categoryId     String
  category       SkillCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  title          String
  subtitle       String
  description    String        @db.Text
  systemPrompt   String        @db.Text
  tags           String[]
  suggestedTools String[]
  exampleInputs  String[]
  difficulty     String        @default("intermediate")
  isActive       Boolean       @default(true)
  sortOrder      Int           @default(0)
  usageCount     Int           @default(0)
  agents         Agent[]
}

model Agent {
  id            String         @id @default(cuid())
  name          String
  role          String
  description   String
  systemPrompt  String         @db.Text
  departmentId  String
  department    Department     @relation(fields: [departmentId], references: [id])
  skillId       String?
  skill         Skill?         @relation(fields: [skillId], references: [id], onDelete: SetNull)
  createdById   String
  createdBy     User           @relation(fields: [createdById], references: [id])
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  isActive      Boolean        @default(true)
  nextAgentId   String?
  nextAgent     Agent?         @relation("AgentChain", fields: [nextAgentId], references: [id])
  prevAgents    Agent[]        @relation("AgentChain")
  knowledgeDocs KnowledgeDoc[]
  taskSteps     TaskStep[]
  startingTasks Task[]         @relation("TaskFirstAgent")
}

model KnowledgeDoc {
  id         String                   @id @default(cuid())
  agentId    String
  agent      Agent                    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  title      String
  sourceType String
  content    String                   @db.Text
  embedding  Unsupported("vector(1536)")?
  createdAt  DateTime                 @default(now())
}

model Task {
  id           String     @id @default(cuid())
  title        String
  description  String     @db.Text
  status       String     @default("pending")
  createdById  String
  createdBy    User       @relation(fields: [createdById], references: [id])
  createdAt    DateTime   @default(now())
  completedAt  DateTime?
  firstAgentId String
  firstAgent   Agent      @relation("TaskFirstAgent", fields: [firstAgentId], references: [id])
  steps        TaskStep[]
  finalOutput  String?    @db.Text
}

model TaskStep {
  id          String    @id @default(cuid())
  taskId      String
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  agentId     String
  agent       Agent     @relation(fields: [agentId], references: [id])
  stepNumber  Int
  input       String    @db.Text
  output      String?   @db.Text
  status      String    @default("pending")
  startedAt   DateTime?
  completedAt DateTime?
  tokensUsed  Int?
}
